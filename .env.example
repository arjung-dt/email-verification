# Email-verification provider API keys.
#
# At least one is required for per-mailbox verification. The verifier chain
# runs them in this exact priority order, stopping at the first definitive
# answer (valid / invalid). Daily-reset providers come first so we burn the
# cheaper-to-replenish credit before falling back to monthly-reset providers.
#
# Free tier (no credit card required for any of these):
#   QEV          — 100/day  = ~3000/month  (daily reset)
#   MEV          — 100/day  = ~3000/month  (daily reset)
#   Abstract     — 100/month                (monthly reset)
#   Mailboxlayer — 100/month                (monthly reset)
#   Hunter       — 50 credits/month = ~100  (monthly reset)
# ---------------------------------------------------------------------------

# QuickEmailVerification — https://quickemailverification.com
QEV_API_KEY=

# MyEmailVerifier — https://myemailverifier.com
MEV_API_KEY=

# Abstract API (Email Validation product) — https://www.abstractapi.com/api/email-verification-validation-api
ABSTRACT_API_KEY=

# Mailboxlayer (apilayer family) — https://mailboxlayer.com
MAILBOXLAYER_API_KEY=

# Hunter.io — https://hunter.io
HUNTER_API_KEY=
